## Networking
MONITORING_BIND_IP=127.0.0.1
MONITORING_NETWORK_NAME=monitoring_net

## Images
VICTORIAMETRICS_IMAGE=victoriametrics/victoria-metrics:v1.118.0
GRAFANA_IMAGE=grafana/grafana:11.6.1
NODE_EXPORTER_IMAGE=quay.io/prometheus/node-exporter:v1.9.1
CADVISOR_IMAGE=ghcr.io/google/cadvisor@sha256:e02855207ec07bb45ee41f720645945251f093f24c28f8c29cf718490f784922
MARIADB_EXPORTER_IMAGE=prom/mysqld-exporter:v0.15.1
POSTGRES_EXPORTER_IMAGE=prometheuscommunity/postgres-exporter:v0.15.0
BLACKBOX_EXPORTER_IMAGE=quay.io/prometheus/blackbox-exporter:v0.25.0

## Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_before_deploy
GRAFANA_SMTP_ENABLED=false
GRAFANA_HOST_PORT=3000
GRAFANA_INTERNAL_PORT=3000
GRAFANA_DATA_DIR=./.data/grafana
GRAFANA_LOGS_DIR=./.data/grafana-logs
GRAFANA_PROVISIONING_DIR=./grafana/provisioning
GRAFANA_DASHBOARDS_DIR=./grafana/dashboards
GRAFANA_CONTAINER_USER=0

## Cloudflare Tunnel (Phase 1 edge access)
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.2.1
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_GRAFANA_HOSTNAME=grafana.example.com

## VictoriaMetrics
VM_RETENTION_PERIOD=90d
VM_HOST_PORT=8428
VM_INTERNAL_PORT=8428
VM_DATA_DIR=./.data/victoriametrics
VM_SCRAPE_CONFIG_PATH=./victoria-metrics/scrape-config.yml
VM_SCRAPE_CONFIG_FILE=scrape-config.yml
VM_MEMORY_LIMIT=2g
VM_MEMORY_SWAP_LIMIT=2g
VM_DATASOURCE_URL=http://victoriametrics:8428

## Node Exporter
NODE_EXPORTER_HOST_PORT=9100
NODE_EXPORTER_INTERNAL_PORT=9100
HOST_ROOTFS_PATH=/
HOST_UDEV_PATH=/run/udev

## cAdvisor
CADVISOR_HOST_PORT=8081
CADVISOR_INTERNAL_PORT=8081

## Phase 2 networks (external Docker networks from app stacks)
KOHANET_NETWORK_NAME=koha-deploy_kohanet
DSPACENET_NETWORK_NAME=dspacenet

## MariaDB Exporter
MARIADB_EXPORTER_HOST_PORT=9104
MARIADB_EXPORTER_INTERNAL_PORT=9104
MARIADB_EXPORTER_TARGET=koha-deploy-db-1:3306
MARIADB_EXPORTER_USER=metrics_reader
MARIADB_EXPORTER_PASSWORD=change_me

## Database exporters
MARIADB_EXPORTER_DSN=user:password@tcp(127.0.0.1:3306)/
POSTGRES_EXPORTER_DSN=postgresql://user:password@127.0.0.1:5432/postgres?sslmode=disable

## PostgreSQL Exporter
POSTGRES_EXPORTER_HOST_PORT=9187
POSTGRES_EXPORTER_INTERNAL_PORT=9187

## Alert delivery
MS365_ALERT_EMAIL_FROM=
MS365_ALERT_FROM_NAME=KDI Monitoring
MS365_ALERT_EMAIL_TO=ops@example.com,devops@example.com
MS365_SMTP_HOST=
MS365_SMTP_PORT=587
MS365_SMTP_USER=
MS365_SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

## Optional integrations (Phase 2 P1)
ELASTICSEARCH_URL=http://127.0.0.1:9200
RABBITMQ_PROM_URL=http://127.0.0.1:15692/metrics
KDV_METRICS_URL=http://127.0.0.1:5001/metrics

## Website probes (Phase 4)
KOHA_OPAC_URL=https://opac.example.com
KOHA_STAFF_URL=https://staff.example.com
